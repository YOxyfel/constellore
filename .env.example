# Runtime mode. Production disables development-only entitlement endpoints.
NODE_ENV=development
CONSTELLORE_ENABLE_TEST_STORE=false

# HTTP listener.
PORT=4173

# Optional immutable deployment identifiers surfaced by /livez and /readyz.
# Hosted Git revisions are used automatically when the platform exposes one.
CONSTELLORE_BUILD_VERSION=
CONSTELLORE_GRAPH_VERSION=

# Optional path for the single-process MVP JSON store.
# Use a durable absolute path in hosted demos. Production commerce should use a
# transactional database and append-only wallet ledger instead.
CONSTELLORE_DATA_PATH=./data/constellore.json

# Safe backups are written at startup and every 24 hours for a durable store.
# The default directory is a "backups" folder beside CONSTELLORE_DATA_PATH.
# Retention is clamped to 1-30 files. Copy production backups off-site.
CONSTELLORE_BACKUP_DIR=./data/backups
CONSTELLORE_BACKUP_KEEP=7

# Optional high-entropy operator secret (at least 24 bytes). When blank or too
# short, aggregate analytics, aggregate recipe feedback, and manual-backup
# endpoints intentionally respond as not found. Never expose this to a client.
CONSTELLORE_ADMIN_TOKEN=

# Exact comma-separated website origins allowed to use the anonymous Launch
# Wishlist across origins. Same-origin requests work without this setting.
INTEREST_ALLOWED_ORIGINS=https://yoxyfel.github.io

# Exact comma-separated browser origins allowed to send authenticated API
# writes or aggregate analytics across origins. Same-origin requests work
# without these settings. Keep both lists narrow; never use a wildcard.
APP_ALLOWED_ORIGINS=
ANALYTICS_ALLOWED_ORIGINS=

# Optional: enables novel AI combinations and custom target route generation.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano

# Fail-closed AI cost and availability limits. Values outside the server's
# safe ranges are clamped. Official ranked recipes never require live AI.
CONSTELLORE_AI_TIMEOUT_MS=12000
CONSTELLORE_AI_MAX_CONCURRENT=2
CONSTELLORE_AI_DAILY_LIMIT=250

# Optional: hosted checkout or store landing page for the cosmetic Supporter Pack.
# Billing is enabled only when this is a valid URL AND fulfillment readiness is
# true. Readiness must stay false until trusted receipt/webhook verification,
# idempotent reconciliation, and authoritative entitlement writes are live.
# Neither setting can grant Star Credits; Star Credits are earn-only.
NEBULA_CHECKOUT_URL=
CONSTELLORE_COMMERCE_FULFILLMENT_READY=false
NEBULA_PRICE=€6.99

# Enable only when a native/web rewarded-ad adapter exposes window.constelloreAds.
REWARDED_ADS_ENABLED=false
